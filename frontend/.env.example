# Vite only exposes env vars prefixed with VITE_ to browser code.
# Copy this file to frontend/.env and paste your Mapbox public token (pk.eyJ...).
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# Local dev: point to the backend directly. In production (behind nginx), leave blank.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/live
