# Sentinel Environment Configuration
# Copy to .env and fill in real values

# ACLED API (register at acleddata.com/user/register)
# ACLED uses OAuth — email + password of your myACLED account
ACLED_EMAIL=your_email@example.com
ACLED_PASSWORD=your_acled_password

# Mapbox (for frontend map tiles)
MAPBOX_TOKEN=your_mapbox_token

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Cassandra
CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=sentinel

# AWS (Phase 5 only)
AWS_REGION=us-east-1
S3_BUCKET=sentinel-raw-events
